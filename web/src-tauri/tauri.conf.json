{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pretty Lattice",
  "version": "0.2.0",
  "identifier": "io.prettylattice.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "splash",
        "url": "splash.html",
        "title": "Pretty Lattice",
        "width": 420,
        "height": 220,
        "resizable": false,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["binaries/prl-server/**/*"],
    "shortDescription": "Publication-ready crystal structure figures.",
    "longDescription": "Pretty Lattice renders crystal structures as publication-ready figures, with trajectory, structure, and electronic-property analysis.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
